# Copy to .env and fill in. Only ANTHROPIC_API_KEY is required.
# cp .env.example .env

# --- LLM brain: provider + model ---
# Pluggable across vendors. LLM_PROVIDER is one of:
#   anthropic | openai | gemini | ollama | vllm | custom
# Anthropic uses its native API; all others go through an OpenAI-compatible
# endpoint (OpenAI, Gemini via its OpenAI endpoint, Ollama, vLLM, Triton, …).
LLM_PROVIDER=anthropic

# Model name for the chosen provider, e.g.:
#   anthropic -> claude-opus-4-8 / claude-sonnet-4-6 / claude-haiku-4-5
#   openai    -> gpt-4o-mini      gemini -> gemini-2.0-flash      ollama -> mistral:7b
LLM_MODEL=claude-opus-4-8

# API keys per provider (only the one you use is needed). Each can also be set
# at runtime from the admin console instead of here.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=
GEMINI_API_KEY=
# VLLM_API_KEY / LLM_API_KEY -> optional keys for vllm / custom OpenAI-compatible servers.

# Ollama / OpenAI-compatible endpoint. The host's Ollama is reached from the
# container at host.docker.internal (mapped in docker-compose). For vllm/custom,
# set the base URL in the admin console (or LLM_BASE_URL is overridden there).
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Provider, model, base URL, API key, system prompt, TTS voice and Whisper model
# are all editable at runtime from the admin console (http://localhost:3000/admin)
# — no env edit or restart needed.

# Always wrap the admin-set role prompt with fixed guardrails (prompt-injection
# protection): the caller can't change the agent's role or reveal its config.
ENFORCE_GUARDRAILS=true

# --- STT (self-hosted faster-whisper) ---
# On this Mac, Docker runs Whisper on CPU. tiny.en/base.en keep latency sane.
# In production on a GPU node set WHISPER_DEVICE=cuda and a larger model.
WHISPER_MODEL=base.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# --- TTS (self-hosted Piper) ---
# Voice is baked into the tts image at build time (see services/tts/Dockerfile).
TTS_VOICE=en_US-ryan-high

# --- Verification gate (one-time code before a call can start) ---
# A caller proves ownership of an email, an order's contact, or a phone number
# and enters the code to unlock the voice session. With NO provider configured
# below, the agent runs in "dev mode": it logs the code and the web UI shows it,
# so the whole flow is testable locally with zero setup.
APP_NAME=Voice AI
OTP_LENGTH=6
OTP_TTL_SECONDS=600        # code lifetime (10 min)
OTP_MAX_ATTEMPTS=5
TICKET_TTL_SECONDS=600     # how long a verified ticket can start a call

# Demo orders for the "Order ID" channel: id:email[:phone], comma-separated.
# Replace with your own data source in production (see services/agent/persistence.py).
ORDERS_SEED=ORD-1001:customer@example.com:+15555550123,ORD-1002:buyer@example.com

# Email delivery (SMTP). Leave SMTP_HOST empty to log codes instead (dev mode).
# These are just defaults — the email account is also editable at runtime from the
# admin console (Email tab), which overrides these and persists in Postgres.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM=no-reply@voice.local

# SMS delivery (Twilio). Leave these empty to log codes instead (dev mode).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Admin console (http://localhost:3000/admin) ---
# Protects /admin/* (live config, call monitoring, logs). If unset, a dev
# default ("voice-admin") is used and a warning is logged — set this in prod.
ADMIN_TOKEN=

# --- Call audio recording ---
# Records each call (merged user + agent) to a WAV under RECORDINGS_DIR, with
# metadata in Postgres; play/download from the admin Calls tab. In Docker this
# path is a named volume (see docker-compose.yml). For production use an
# object-store-backed mount (S3/GCS).
RECORD_AUDIO=true
RECORDINGS_DIR=/data/recordings
